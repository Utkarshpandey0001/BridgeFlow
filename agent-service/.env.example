PORT=3001
NODE_ENV=development

# Stacks network (mainnet | testnet | devnet)
STACKS_NETWORK=testnet
STACKS_API_URL=https://api.testnet.hiro.so

# Vault contract address (update after deploy)
VAULT_CONTRACT_ADDRESS=ST...your_address...
VAULT_CONTRACT_NAME=vault

# USDC token contract
USDC_CONTRACT_ADDRESS=ST...your_address...
USDC_CONTRACT_NAME=usdc-token

# Agent executor private key (hex) — deploy wallet for testnet
AGENT_PRIVATE_KEY=your_private_key_hex_here

# Oracle APIs
PYTH_API_URL=https://hermes.pyth.network/api
AAVE_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/aave/protocol-v3
ZEST_API_URL=https://api.zestprotocol.com

# Database
SQLITE_PATH=./data/bitflow.db

# CORS allowed origins (frontend URL)
CORS_ORIGIN=http://localhost:3000
